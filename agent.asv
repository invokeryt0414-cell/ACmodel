classdef agent

    properties
        position
        body
    end

    methods

        function obj = agent()

            obj.position = [10 10];
            obj.body = body();

        end
        function obj = move(obj)

            obj.position(1) = obj.position(1) + randi([-1 1]);
            obj.position(2) = obj.position(2) + randi([-1 1]);
        
        end


    end

end